# ──────────────────────────────────────────────────────────
# Axon Rust — Environment Variables
# Copy to .env and fill in values before running.
# ──────────────────────────────────────────────────────────

# === PostgreSQL ===
# MUST be set — used by both docker-compose and the CLI
POSTGRES_USER=axon
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=axon
AXON_PG_URL=postgresql://axon:CHANGE_ME@axon-postgres:5432/axon

# === Redis ===
# Password must match the --requirepass flag in docker-compose
REDIS_PASSWORD=CHANGE_ME
AXON_REDIS_URL=redis://:CHANGE_ME@axon-redis:6379

# === RabbitMQ ===
# MUST be set — guest:guest is rejected for non-localhost connections
RABBITMQ_USER=axon
RABBITMQ_PASS=CHANGE_ME
AXON_AMQP_URL=amqp://axon:CHANGE_ME@axon-rabbitmq:5672

# === Qdrant (no auth required) ===
QDRANT_URL=http://axon-qdrant:6333

# === TEI Embeddings (external — required for embed/query/ask) ===
TEI_URL=http://REPLACE_WITH_TEI_HOST:52000

# === Optional queue name overrides ===
AXON_CRAWL_QUEUE=axon.crawl.jobs
AXON_BATCH_QUEUE=axon.batch.jobs
AXON_EXTRACT_QUEUE=axon.extract.jobs
AXON_EMBED_QUEUE=axon.embed.jobs

# === LLM (required for extract and ask commands) ===
OPENAI_BASE_URL=http://REPLACE_WITH_OPENAI_BASE/v1
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gemini-3-flash-preview
