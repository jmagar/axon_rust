exports[`pulse chat pane snapshots > renders compact empty-state header 1`] = `"<div class="flex h-full min-h-0 flex-col"><div class="flex min-h-0 flex-1 flex-col space-y-2.5 overflow-y-auto px-3 py-2.5"><div class="flex h-full items-center justify-center p-6"><div class="flex max-w-sm flex-col items-center gap-4 rounded-xl border border-[var(--border-standard)] bg-[linear-gradient(135deg,rgba(135,175,255,0.08),rgba(255,135,175,0.05))] p-6 text-center shadow-[var(--shadow-lg)] animate-scale-in"><div class="relative"><div class="absolute inset-0 bg-[radial-gradient(circle,rgba(135,175,255,0.25),transparent_60%)] blur-xl"></div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle relative size-10 text-[var(--axon-primary)]" aria-hidden="true"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"></path></svg></div><div class="space-y-1.5"><h2 class="font-display text-base font-semibold text-[var(--text-primary)]">Start a conversation</h2><p class="text-sm leading-relaxed text-[var(--text-secondary)]">Ask Claude to write, analyze, or explore. Paste a URL in the omnibox to run a tool on a webpage.</p></div><div class="flex flex-wrap justify-center gap-2 pt-1"><span class="inline-flex items-center gap-1 rounded-full border border-[var(--border-subtle)] bg-[rgba(135,175,255,0.08)] px-2.5 py-1 text-xs text-[var(--axon-primary)]"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-send size-2.5" aria-hidden="true"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"></path><path d="m21.854 2.147-10.94 10.939"></path></svg>Ask a question</span><span class="inline-flex items-center gap-1 rounded-full border border-[var(--border-subtle)] bg-[rgba(255,135,175,0.08)] px-2.5 py-1 text-xs text-[var(--axon-secondary)]">Paste a URL</span></div></div></div></div></div>"`;

exports[`pulse chat pane snapshots > renders notice + sources state 1`] = `"<div class="flex h-full min-h-0 flex-col"><div class="border-b border-[var(--border-subtle)] bg-[linear-gradient(120deg,rgba(175,215,255,0.05),rgba(255,135,175,0.03))] px-3 py-2"><div class="mt-1 rounded border border-[rgba(255,192,134,0.3)] bg-[rgba(255,192,134,0.08)] px-1.5 py-1 ui-meta text-[var(--axon-warning)]">Previous request replaced by your latest prompt.</div></div><div class="flex min-h-0 flex-1 flex-col space-y-2.5 overflow-y-auto px-3 py-2.5"><div class="flex w-full justify-end"><article class="w-full space-y-1.5 animate-fade-in-up mr-4 max-w-[80%]" style="animation-delay:0ms"><div class="rounded-xl border px-3 py-2.5 border-[var(--border-standard)] bg-[linear-gradient(140deg,rgba(135,175,255,0.28),rgba(135,175,255,0.12))] shadow-[var(--shadow-md)] text-[var(--text-primary)]"><div class="mb-1.5 flex items-center justify-between gap-2"><span class="inline-flex items-center gap-1 text-[length:var(--text-2xs)] font-semibold uppercase tracking-[0.1em] text-[var(--axon-primary)]"><span class="inline-block size-1.5 rounded-full bg-[var(--axon-primary-strong)]"></span>You</span><span class="text-[11px] text-[var(--text-muted)] font-medium">10:13 PM</span></div><p class="ui-copy whitespace-pre-wrap">Summarize this crawl.</p></div></article></div><div class="flex w-full justify-start"><article class="w-full space-y-1.5 animate-fade-in-up ml-2 max-w-[80%]" style="animation-delay:25ms"><div class="rounded-xl border px-3 py-2.5 border-[rgba(255,135,175,0.18)] bg-[linear-gradient(140deg,rgba(255,135,175,0.1),rgba(10,18,35,0.55))] shadow-[0_6px_18px_rgba(3,7,18,0.3)] text-[var(--text-secondary)]"><div class="mb-1.5 flex items-center justify-between gap-2"><span class="inline-flex items-center gap-1 text-[length:var(--text-2xs)] font-semibold uppercase tracking-[0.1em] text-[var(--axon-secondary-strong)]"><span class="inline-block size-1.5 rounded-full bg-[var(--axon-secondary)]"></span>Cortex</span><span class="text-[11px] text-[var(--text-muted)] font-medium">10:13 PM</span></div><div class="space-y-0.5"><div><p class="text-[length:var(--text-md)] leading-[var(--leading-copy)] text-[var(--text-secondary)]">Working through indexed context.</p></div></div></div></article></div><div class="flex items-start gap-3 rounded-xl border border-[var(--border-subtle)] bg-[var(--surface-elevated)] px-3 py-2.5 shadow-[var(--shadow-sm)] animate-fade-in"><div class="mt-0.5 flex shrink-0 gap-0.5"><span class="inline-block size-1.5 rounded-full bg-[var(--axon-primary)]" style="animation:breathing 1.4s ease-in-out 0ms infinite"></span><span class="inline-block size-1.5 rounded-full bg-[var(--axon-primary)]" style="animation:breathing 1.4s ease-in-out 200ms infinite"></span><span class="inline-block size-1.5 rounded-full bg-[var(--axon-primary)]" style="animation:breathing 1.4s ease-in-out 400ms infinite"></span></div><div class="min-w-0 flex-1"><span class="animate-breathing text-sm text-[var(--text-secondary)]">Thinking…</span></div></div></div></div>"`;
