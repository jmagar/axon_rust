# Keep the web build context small — source is bind-mounted at runtime anyway.
# Only package manifests (package.json, pnpm-lock.yaml) need to be in the image.

# Build artifacts — excluded from context; anonymous volumes own these at runtime
.next
node_modules

# Dev/tool artifacts
.env
.env.*
!.env.example
*.log
*.tmp
.DS_Store

# Test output
coverage
playwright-report
test-results
