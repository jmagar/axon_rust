#!/command/with-contenv bash
# shellcheck shell=bash
# Called by s6 when the ingest-worker process exits.
# $1 = exit code of the run script; $2 = signal that killed it (or -1 if exited normally)
exit_code="${1:-?}"
signal="${2:--1}"

if [ "$exit_code" -ne 0 ] || [ "$signal" -ne -1 ]; then
    echo "[ingest-worker] UNEXPECTED EXIT — code=${exit_code} signal=${signal} — s6 will restart" >&2
else
    echo "[ingest-worker] clean exit — code=${exit_code}" >&2
fi
