#!/command/with-contenv bash
# shellcheck shell=bash
set -e
cd /app

mkdir -p /home/axon/.codex
if [ -f /run/host-codex/config.toml ]; then
  install -o axon -g axon -m 600 /run/host-codex/config.toml /home/axon/.codex/config.toml
fi
if [ -f /run/host-codex/auth.json ]; then
  install -o axon -g axon -m 600 /run/host-codex/auth.json /home/axon/.codex/auth.json
fi
if [ -f /run/host-codex/models_cache.json ]; then
  install -o axon -g axon -m 644 /run/host-codex/models_cache.json /home/axon/.codex/models_cache.json
fi

exec s6-setuidgid axon /usr/local/bin/axon serve --port 49000
