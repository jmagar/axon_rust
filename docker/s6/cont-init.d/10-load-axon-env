#!/command/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

env_file="${AXON_ENV_FILE:-/app/.env}"

if [[ ! -f "$env_file" ]]; then
  echo "[cont-init] env file not found at $env_file, using runtime environment only"
else
  echo "[cont-init] loading environment from $env_file"

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^[[:space:]]*# ]] && continue

    line="${line#export }"
    line="${line%$'\r'}"

    # Skip lines without '=' (bare variable names)
    [[ "$line" != *=* ]] && continue

    key="${line%%=*}"
    value="${line#*=}"

    key="$(echo "$key" | tr -d '[:space:]')"
    [[ -z "$key" ]] && continue

    # Validate key is a valid shell identifier
    if [[ ! "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
      echo "[cont-init] WARNING: skipping invalid key '$key'" >&2
      continue
    fi

    if [[ "$value" != \"* && "$value" != \'* ]]; then
      value="${value%%[[:space:]]#*}"
      value="${value%"${value##*[![:space:]]}"}"
    fi

    if [[ "$value" =~ ^\".*\"$ ]]; then
      value="${value#\"}"
      value="${value%\"}"
    elif [[ "$value" =~ ^\'.*\'$ ]]; then
      value="${value#\'}"
      value="${value%\'}"
    fi

    if [[ -z "${!key+x}" ]]; then
      export "$key=$value"
    fi
  done < "$env_file"
fi

output_dir="${AXON_OUTPUT_DIR:-/app/.cache/axon-rust/output}"

# Validate output_dir is non-empty and under an expected prefix
if [[ -z "$output_dir" ]]; then
  echo "[cont-init] ERROR: output_dir is empty, refusing to chown/chmod" >&2
  exit 1
fi

# Resolve to absolute path and ensure it's under a safe prefix
resolved_dir="$(realpath -m "$output_dir")"
case "$resolved_dir" in
  /app/*|/home/*|/data/*|/tmp/*)
    ;;
  *)
    echo "[cont-init] ERROR: output_dir '$resolved_dir' is not under /app/, /home/, /data/, or /tmp/" >&2
    exit 1
    ;;
esac

mkdir -p "$resolved_dir"
chown -R axon:axon "$resolved_dir"
chmod -R u+rwX,g+rwX "$resolved_dir"

artifact_dir="${AXON_MCP_ARTIFACT_DIR:-/app/.cache/axon-mcp}"

resolved_artifact="$(realpath -m "$artifact_dir")"
case "$resolved_artifact" in
  /app/*|/home/*|/data/*|/tmp/*) ;;
  *)
    echo "[cont-init] ERROR: AXON_MCP_ARTIFACT_DIR '$resolved_artifact' is not under a safe prefix" >&2
    exit 1
    ;;
esac

mkdir -p "$resolved_artifact"
chown -R axon:axon "$resolved_artifact"
chmod -R u+rwX,g+rwX "$resolved_artifact"

diag_dir="${AXON_CHROME_DIAGNOSTICS_DIR:-/app/.cache/chrome-diagnostics}"

resolved_diag="$(realpath -m "$diag_dir")"
case "$resolved_diag" in
  /app/*|/home/*|/data/*|/tmp/*) ;;
  *)
    echo "[cont-init] ERROR: AXON_CHROME_DIAGNOSTICS_DIR '$resolved_diag' is not under a safe prefix" >&2
    exit 1
    ;;
esac

mkdir -p "$resolved_diag"
chown -R axon:axon "$resolved_diag"
chmod -R u+rwX,g+rwX "$resolved_diag"

host_codex_dir="/run/host-codex"
target_codex_dir="/home/axon/.codex"

copy_if_present() {
  local source_path="$1"
  local target_path="$2"
  local mode="$3"

  if [[ ! -f "$source_path" ]]; then
    return 0
  fi

  install -o axon -g axon -m "$mode" "$source_path" "$target_path"
}

mkdir -p "$target_codex_dir"
copy_if_present "$host_codex_dir/config.toml" "$target_codex_dir/config.toml" 600
copy_if_present "$host_codex_dir/auth.json" "$target_codex_dir/auth.json" 600
copy_if_present "$host_codex_dir/models_cache.json" "$target_codex_dir/models_cache.json" 644
