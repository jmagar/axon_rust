#!/command/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

# Ensure ACP adapters can persist local state under the axon user's home.
# Never recurse here: mounted host subpaths (e.g. ~/.claude/projects,
# ~/.codex/sessions, ~/.gemini) must keep host ownership.
AGENT_HOME="/home/axon"

for dir in ".claude" ".codex" ".gemini"; do
  target="${AGENT_HOME}/${dir}"
  if [[ ! -d "$target" ]]; then
    mkdir -p "$target"
  fi
  chown axon:axon "$target"
  chmod u+rwx,g+rx "$target"
done

echo "[15-fix-agent-home-ownership] ensured top-level ownership for ${AGENT_HOME}/{.claude,.codex,.gemini} (non-recursive)" >&2
