#!/command/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

# Copy host-mounted Claude config files into axon's home directory with correct
# ownership.  Host files are mounted read-only at staging paths under
# /run/host-claude/ so that host permissions (0600/0640 uid=HOST) are never
# modified.  We copy each file here as root and chown the *copy* to the axon
# user, allowing claude-agent-acp to read and refresh OAuth tokens without
# writing back to the host files.

STAGING_DIR="/run/host-claude"
CLAUDE_HOME="/home/axon/.claude"
AXON_HOME="/home/axon"

mkdir -p "$CLAUDE_HOME"

copy_if_present() {
  local src="$1"
  local dst="$2"
  if [[ -f "$src" ]]; then
    install -o axon -g axon -m 600 "$src" "$dst"
    echo "[17-materialize-claude-credentials] copied $(basename "$src") → $dst (owned by axon)" >&2
  else
    echo "[17-materialize-claude-credentials] $src not found — skipping" >&2
  fi
}

copy_if_present "${STAGING_DIR}/.credentials.json" "${CLAUDE_HOME}/.credentials.json"
copy_if_present "${STAGING_DIR}/claude.json"       "${AXON_HOME}/.claude.json"
