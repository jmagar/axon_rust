#!/command/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

HOST_CODEX_DIR="/run/host-codex"
TARGET_CODEX_DIR="/home/axon/.codex"

mkdir -p "${TARGET_CODEX_DIR}"

copy_if_present() {
  local source_path="$1"
  local target_path="$2"
  local mode="$3"

  if [[ ! -f "${source_path}" ]]; then
    return 0
  fi

  install -o axon -g axon -m "${mode}" "${source_path}" "${target_path}"
}

copy_if_present "${HOST_CODEX_DIR}/config.toml" "${TARGET_CODEX_DIR}/config.toml" 600
copy_if_present "${HOST_CODEX_DIR}/auth.json" "${TARGET_CODEX_DIR}/auth.json" 600
copy_if_present "${HOST_CODEX_DIR}/models_cache.json" "${TARGET_CODEX_DIR}/models_cache.json" 644

echo "[16-materialize-codex-config] refreshed /home/axon/.codex from /run/host-codex" >&2
