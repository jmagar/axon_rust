#!/command/with-contenv sh
# Sync node_modules with pnpm-lock.yaml on every container start.
#
# The anonymous volume at /app/node_modules is populated at image build time.
# When new packages are added to pnpm-lock.yaml, the volume goes stale until
# pnpm install is run. This script checks a sentinel file timestamp against
# pnpm-lock.yaml and reinstalls only when the lockfile changed.

LOCKFILE="/app/pnpm-lock.yaml"
SENTINEL="/app/node_modules/.pnpm-install-stamp"

if [ ! -f "$LOCKFILE" ]; then
    echo "[20-pnpm-install] pnpm-lock.yaml not found — skipping" >&2
    exit 0
fi

# Install if sentinel is missing or lockfile is newer
if [ ! -f "$SENTINEL" ] || [ "$LOCKFILE" -nt "$SENTINEL" ]; then
    echo "[20-pnpm-install] pnpm-lock.yaml changed — running pnpm install" >&2
    if cd /app && CI=true s6-setuidgid node pnpm install --frozen-lockfile >&2; then
        touch "$SENTINEL"
        echo "[20-pnpm-install] done" >&2
    else
        echo "[20-pnpm-install] pnpm install failed — sentinel NOT updated" >&2
        exit 1
    fi
else
    echo "[20-pnpm-install] node_modules up to date — skipping" >&2
fi
