#!/command/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

# Copy host-mounted ACP adapter credential files into the node user's home
# directory with correct ownership.  Host files are staged read-only under
# /run/host-claude/ and /run/host-codex/ so their host permissions (0600/0640
# uid=HOST) are never modified.  We copy each file here as root and chown the
# *copy* to the node user, allowing claude-agent-acp / codex to read and
# refresh OAuth tokens without touching the original host files.
#
# This is needed because:
#   - /home/node/.claude is a named data volume (not a host bind-mount), so
#     host credential files are not present by default.
#   - /api/agents/route.ts calls `claude agents` which requires OAuth creds.
#   - /home/node/.codex is similarly a container-local directory; codex needs
#     auth.json and config.toml for ACP sessions.

CLAUDE_STAGING="/run/host-claude"
CLAUDE_HOME="/home/node/.claude"

CODEX_STAGING="/run/host-codex"
CODEX_HOME="/home/node/.codex"

mkdir -p "$CLAUDE_HOME" "$CODEX_HOME"

copy_if_present() {
  local src="$1"
  local dst="$2"
  if [[ -f "$src" ]]; then
    install -o node -g node -m 600 "$src" "$dst"
    echo "[16-materialize-agent-credentials] copied $(basename "$src") → $dst (owned by node)" >&2
  else
    echo "[16-materialize-agent-credentials] $src not found — skipping" >&2
  fi
}

copy_if_present "${CLAUDE_STAGING}/.credentials.json"  "${CLAUDE_HOME}/.credentials.json"
copy_if_present "${CODEX_STAGING}/auth.json"            "${CODEX_HOME}/auth.json"
copy_if_present "${CODEX_STAGING}/config.toml"          "${CODEX_HOME}/config.toml"
copy_if_present "${CODEX_STAGING}/models_cache.json"    "${CODEX_HOME}/models_cache.json"
