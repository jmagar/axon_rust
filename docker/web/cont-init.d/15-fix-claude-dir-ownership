#!/command/with-contenv bash
# shellcheck shell=bash
# Fix ownership of ~/.claude subdirectories so the node user (UID 1000) can write
# session data (todos, projects, debug, cache, history).
#
# These dirs are bind-mounted from the host (${AXON_DATA_DIR}/axon/claude) and may
# be owned by root if they were first created by a root process (e.g. docker exec
# as root, or a previous Claude Code session running without this fix). Claude CLI
# refuses to run under --dangerously-skip-permissions when it can't write its state,
# so Pulse chat gets "Claude CLI exited 1" until ownership is fixed.
#
# This script runs as root (PID 1 s6-overlay lifecycle), so chown succeeds regardless
# of the current ownership. It runs on every container start; chown on already-correct
# ownership is a no-op.

# Use the node user's home directly — $HOME resolves to /root when this cont-init
# script runs as PID 1 (s6-overlay requires root at init time), which would silently
# skip the actual /home/node/.claude bind-mount.
CLAUDE_DIR="/home/node/.claude"

if [ ! -d "$CLAUDE_DIR" ]; then
    echo "[15-fix-claude-dir-ownership] ${CLAUDE_DIR} not found — skipping" >&2
    exit 0
fi

chown -R node:node "$CLAUDE_DIR"
echo "[15-fix-claude-dir-ownership] fixed ownership of ${CLAUDE_DIR}" >&2
