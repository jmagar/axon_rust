#!/command/with-contenv bash
# shellcheck shell=bash
# Pre-trust the workspace directory in ~/.claude.json so claude-session starts
# without showing the "Do you trust this folder?" dialog.
#
# ~/.claude.json is bind-mounted from the host, so this change is persistent
# across container restarts. The entry is additive — existing entries are preserved.
# Only writes if /workspace is not already trusted.

CLAUDE_JSON="${HOME:-/home/node}/.claude.json"
WORKSPACE="${AXON_WORKSPACE:-/workspace}"

if [ ! -f "$CLAUDE_JSON" ]; then
    echo "[10-trust-workspace] ${CLAUDE_JSON} not found — skipping workspace trust setup" >&2
    exit 0
fi

# Use node (always available in this image) to patch ~/.claude.json
node - "$CLAUDE_JSON" "$WORKSPACE" <<'JSEOF'
const fs = require('fs')
const [, , path, workspace] = process.argv
const raw = fs.readFileSync(path, 'utf8')
const d = JSON.parse(raw)
if (!d.projects) d.projects = {}
const entry = d.projects[workspace] || {}
if (entry.hasTrustDialogAccepted) {
    process.stderr.write(`[10-trust-workspace] ${workspace} is already trusted — nothing to do\n`)
    process.exit(0)
}
d.projects[workspace] = { ...entry, hasTrustDialogAccepted: true }
fs.writeFileSync(path, JSON.stringify(d, null, 2) + '\n')
process.stderr.write(`[10-trust-workspace] pre-trusted ${workspace} in ${path}\n`)
JSEOF
