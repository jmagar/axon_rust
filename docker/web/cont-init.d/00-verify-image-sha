#!/command/with-contenv bash
set -euo pipefail

fail() {
  echo "[sha-guard] ERROR: $1"
  touch /run/sha-guard-failed
  exit 1
}

enforce="${AXON_ENFORCE_IMAGE_SHA:-true}"
if [[ "$enforce" != "true" ]]; then
  echo "[sha-guard] AXON_ENFORCE_IMAGE_SHA=false, skipping image revision verification"
  rm -f /run/sha-guard-failed
  exit 0
fi

if [[ ! -e /repo/.git ]]; then
  fail "/repo/.git not found. Mount repo root to /repo to enforce stale-image protection."
fi

host_sha="$(git -c safe.directory=/repo -C /repo rev-parse HEAD 2>/dev/null || true)"
image_sha="${AXON_IMAGE_GIT_SHA:-}"

if [[ -z "$host_sha" ]]; then
  fail "failed to resolve host git HEAD from /repo"
fi

if [[ -z "$image_sha" || "$image_sha" == "dev" ]]; then
  fail "container image SHA missing or dev placeholder"
fi

if [[ "$host_sha" != "$image_sha" ]]; then
  echo "[sha-guard] host HEAD:  $host_sha"
  echo "[sha-guard] image SHA:  $image_sha"
  echo "[sha-guard] run ./scripts/rebuild-fresh.sh"
  fail "stale container image detected"
fi

rm -f /run/sha-guard-failed
echo "[sha-guard] OK: image SHA matches host HEAD ($image_sha)"
