#!/command/with-contenv bash
# shellcheck shell=bash
# Grant the node user access to /var/run/docker.sock so dockerode (used by
# /api/logs) can reach the Docker daemon.
#
# group_add in docker-compose.yaml adds supplementary GIDs to the container's
# root process (/init, PID 1), but s6-setuidgid strips ALL supplementary groups
# when it drops privileges to the node user. Only groups listed in /etc/group
# for that user survive the privilege drop.
#
# This script runs as root during cont-init (before s6 starts any services):
#   1. Reads the socket's GID dynamically (never hardcodes host GID).
#   2. Creates a group with that GID if none exists yet.
#   3. Adds node to that group.
# After this runs, s6-setuidgid node will include the docker socket GID in the
# process's supplementary groups.

SOCK=/var/run/docker.sock

if [ ! -S "$SOCK" ]; then
    echo "[12-docker-socket-group] ${SOCK} not mounted — skipping" >&2
    exit 0
fi

docker_gid=$(stat -c '%g' "$SOCK")

# Create a group with this GID if one doesn't already exist.
if ! getent group "$docker_gid" > /dev/null 2>&1; then
    groupadd -g "$docker_gid" docker-host
    echo "[12-docker-socket-group] created group docker-host (GID ${docker_gid})" >&2
fi

group_name=$(getent group "$docker_gid" | cut -d: -f1)

# Add node to the group (idempotent — usermod -aG is a no-op if already a member).
usermod -aG "$group_name" node
echo "[12-docker-socket-group] node added to ${group_name} (GID ${docker_gid})" >&2
